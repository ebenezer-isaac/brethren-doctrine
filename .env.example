# .env.example
# Voyage AI for embeddings (required)
VOYAGE_API_KEY=

# Lexical Neo4j (Phase 01 brings this up)
NEO4J_LEXICAL_URI=bolt://localhost:7475
NEO4J_LEXICAL_USER=neo4j
NEO4J_LEXICAL_PASSWORD=

# Cultural Neo4j (Phase 01 brings this up)
NEO4J_CULTURAL_URI=bolt://localhost:7476
NEO4J_CULTURAL_USER=neo4j
NEO4J_CULTURAL_PASSWORD=

# Lexical Qdrant
QDRANT_LEXICAL_URL=http://localhost:7100

# Cultural Qdrant
QDRANT_CULTURAL_URL=http://localhost:7101

# MCP server bind
MCP_HOST=127.0.0.1
MCP_PORT=8765

# Do NOT set ANTHROPIC_API_KEY in this file.
# All LLM dispatch is via Claude Code subagents under Max plan.
# Adding ANTHROPIC_API_KEY signals a violation of the orchestrator pattern.

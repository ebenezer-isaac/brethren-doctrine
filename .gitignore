# Secrets
.env
.env.local
.env.*.local

# Private source materials. Contain personal contributor names; never commit.
source-docs/
converted/
.tmp-beliefs/

# Private data. External corpora, cached translations, indexed working sets.
data/
chunks/
embeddings/cache/
parsed/_pending_transcription/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.uv/
dist/
build/

# uv
.python-version

# Logs
logs/
*.log

# IDE
.idea/
.vscode/settings.json

# Docker
docker/data/

# Eval results (per-run output, not source)
eval/results/

# OS
.DS_Store
Thumbs.db

# Per-agent run summaries (orchestration log)
agent-logs/
.tmp-prompts/

# Verifier / question-hygiene reports (regenerated, not source)
verify-report.md
questions-hygiene-report.md

# Trust-report PDFs (regenerated on demand by tools/generate_trust_report.py;
# the tool is committed, the generated PDFs are not).
reports/

# Manifest-verification JSON (regenerable output of tools/verify_manifest.py
# and generate_trust_report.py --verify; the tools are committed, the
# per-run verification artifacts are not).
docs/MANIFEST_VERIFICATION_*.json

# Local backup snapshots (regenerable, never source).
backups/

# Question-reframe backup (pre-apply)
questions.json.*.bak

# Doc subfolders are working scratch (implementation_phases, phase_prompts, archive snapshots).
# Only top-level docs/*.md canonical specs are tracked.
docs/*/

# Sandboxed scratch per phase discipline (D9)
tmp/

# Required gitignore entries (Phase 00 cleanup)
*.pyc
.pytest_cache/
.coverage
.mypy_cache/
responses/
*.bak
